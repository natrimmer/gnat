{
  "name": "root",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "tailwind:dev": "tailwindcss -i ./src/input.css -o ./public/styles.css --watch",
    "tailwind:build": "tailwindcss -i ./src/input.css -o ./public/styles.css",
    "server:dev": "ts-node src/index.ts --watch",
    "server:build": "ts-node src/index.ts",
    "dev": "concurrently --kill-others-on-fail --prefix \"[{name}]\" --names \"SERVER,TAILWIND\" \"npm run server:dev\" \"npm run tailwind:dev\"",
    "build": "npm run tailwind:build && npm run server:build"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@types/html-minifier": "^4.0.5",
    "@types/live-server": "^1.2.3",
    "@types/node": "^22.10.5",
    "@types/prettier": "^3.0.0",
    "chokidar": "^4.0.3",
    "concurrently": "^9.1.2",
    "live-server": "^1.2.2",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@types/winston": "^2.4.4",
    "html-minifier": "^4.0.0",
    "winston": "^3.17.0"
  }
}
